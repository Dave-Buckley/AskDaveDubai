---
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
---
<header class="fixed top-0 left-0 right-0 z-40 bg-ink/95 backdrop-blur-sm border-b border-paper/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Brand -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="font-heading text-xl font-bold text-paper tracking-wide group-hover:text-accent transition-colors duration-200">
          AskDave<span class="text-accent">Downtown</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <Navigation />

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-4">
        <a href="/contact" class="hidden md:inline-flex items-center px-5 py-2 bg-accent text-ink text-sm font-semibold tracking-wide hover:bg-accent/90 transition-colors duration-200">
          Book a Call
        </a>
        <button id="mobile-menu-open" class="md:hidden text-paper p-2" aria-label="Open menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
<MobileMenu />
<!-- Spacer for fixed header -->
<div class="h-16"></div>
