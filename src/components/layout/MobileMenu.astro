---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Areas', href: '/areas' },
  { label: 'Blog', href: '/blog' },
  { label: 'Guides', href: '/guides' },
  { label: 'Ask Dave', href: '/ask-dave' },
  { label: 'Tools', href: '/tools' },
  { label: 'Contact', href: '/contact' },
];
---
<div id="mobile-menu" class="hidden fixed inset-0 z-50 bg-ink" aria-hidden="true">
  <div class="flex flex-col h-full p-6">
    <div class="flex justify-end">
      <button id="mobile-menu-close" aria-label="Close menu" class="text-paper p-2">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <nav class="flex-1 flex items-center">
      <ul class="w-full space-y-6">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="block text-3xl font-heading font-semibold text-paper hover:text-accent transition-colors duration-200">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="pt-6 border-t border-paper/20">
      <a href="/contact" class="block text-center py-4 bg-accent text-ink font-semibold text-sm tracking-widest uppercase">
        Book a Consultation
      </a>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  document.getElementById('mobile-menu-open')?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  });
  closeBtn?.addEventListener('click', () => {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  });
</script>
