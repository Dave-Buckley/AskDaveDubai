---
const base = import.meta.env.BASE_URL;
const mobileItems = [
  { label: 'About', href: `${base}about` },
  { label: 'Downtown Dubai', href: `${base}downtown` },
  { label: 'Buildings', href: `${base}buildings` },
  { label: 'Developers', href: `${base}developers` },
  { label: 'Blog', href: `${base}blog` },
  { label: 'Guides', href: `${base}guides` },
  { label: 'Dubai Essentials', href: `${base}dubai-essentials` },
  { label: 'Things to Do', href: `${base}things-to-do` },
  { label: 'Ask Dave', href: `${base}ask-dave` },
  // DISABLED: Areas, Explore, Compare, Area Finder, Comparisons - Downtown specialist focus
];

const desktopSections = [
  {
    heading: 'Downtown',
    items: [
      { label: 'Why Downtown Dubai', href: `${base}downtown` },
      { label: 'Downtown Buildings', href: `${base}buildings` },
      { label: 'Developers', href: `${base}developers` },
    ]
  },
  {
    heading: 'Learn',
    items: [
      { label: 'Blog', href: `${base}blog` },
      { label: 'Guides', href: `${base}guides` },
      { label: 'Ask Dave Q&A', href: `${base}ask-dave` },
    ]
  },
  {
    heading: 'Dubai Life',
    items: [
      { label: 'Dubai Essentials', href: `${base}dubai-essentials` },
      { label: 'Things to Do', href: `${base}things-to-do` },
    ]
  },
];
---

<!-- Backdrop (click to close) -->
<div id="menu-backdrop" class="hidden fixed inset-0 z-40 md:bg-black/40" aria-hidden="true"></div>

<!-- Mobile: full-screen menu -->
<div id="mobile-menu" class="hidden md:!hidden fixed inset-0 z-50 bg-ink" aria-hidden="true">
  <div class="flex flex-col h-full p-6">
    <div class="flex justify-end">
      <button class="menu-close text-paper p-2" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <nav class="flex-1 flex items-center">
      <ul class="w-full space-y-5">
        {mobileItems.map(item => (
          <li>
            <a href={item.href} class="block text-2xl font-heading font-semibold text-paper hover:text-accent transition-colors duration-200">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="pt-6 border-t border-paper/20 space-y-3">
      <a href="https://wa.me/971503019926" target="_blank" rel="noopener noreferrer"
         class="flex items-center justify-center gap-2 py-3 bg-[#25D366] text-white font-semibold text-sm tracking-wide hover:bg-[#1FAF54] transition-colors duration-200">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Dave
      </a>
      <a href="mailto:dave.buckley@paragonproperties.ae"
         class="flex items-center justify-center gap-2 py-3 border border-paper/20 text-paper font-semibold text-sm tracking-wide hover:border-accent hover:text-accent transition-colors duration-200">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        Email Dave
      </a>
    </div>
  </div>
</div>

<!-- Desktop: dropdown panel -->
<div id="desktop-menu" class="hidden fixed z-50 top-[4.25rem] right-4 sm:right-6 lg:right-8 w-72 bg-ink border border-paper/10 shadow-2xl overflow-y-auto max-h-[calc(100vh-5rem)]" aria-hidden="true">
  <div class="p-5">
    {desktopSections.map((section, i) => (
      <div class={i > 0 ? 'mt-4 pt-4 border-t border-paper/8' : ''}>
        <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase text-paper/30 mb-2.5">{section.heading}</h4>
        <ul class="space-y-1.5">
          {section.items.map(item => (
            <li>
              <a href={item.href} class="block text-sm text-paper/70 hover:text-accent transition-colors duration-200 py-0.5">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="mt-4 pt-4 border-t border-paper/8 flex gap-4">
      <a href={`${base}about`} class="text-sm text-paper/70 hover:text-accent transition-colors duration-200">About</a>
      <a href={`${base}contact`} class="text-sm text-paper/70 hover:text-accent transition-colors duration-200">Contact</a>
    </div>
  </div>

  <div class="border-t border-paper/10 p-4 space-y-2.5">
    <a href="https://wa.me/971503019926" target="_blank" rel="noopener noreferrer"
       class="flex items-center justify-center gap-2 py-2.5 bg-[#25D366] text-white font-semibold text-sm tracking-wide hover:bg-[#1FAF54] transition-colors duration-200">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp Dave
    </a>
    <a href="mailto:dave.buckley@paragonproperties.ae"
       class="flex items-center justify-center gap-2 py-2.5 border border-paper/20 text-paper/80 font-semibold text-sm tracking-wide hover:border-accent hover:text-accent transition-colors duration-200">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
      Email Dave
    </a>
  </div>
</div>

<script>
  const mobileMenu = document.getElementById('mobile-menu');
  const desktopMenu = document.getElementById('desktop-menu');
  const backdrop = document.getElementById('menu-backdrop');
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtns = document.querySelectorAll('.menu-close');

  const isMobile = () => window.innerWidth < 768;

  function isOpen() {
    return !backdrop?.classList.contains('hidden');
  }

  function openMenu() {
    backdrop?.classList.remove('hidden');
    if (isMobile()) {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    } else {
      desktopMenu?.classList.remove('hidden');
      desktopMenu?.setAttribute('aria-hidden', 'false');
    }
  }

  function closeMenu() {
    backdrop?.classList.add('hidden');
    mobileMenu?.classList.add('hidden');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    desktopMenu?.classList.add('hidden');
    desktopMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', () => {
    if (isOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  backdrop?.addEventListener('click', closeMenu);
  closeBtns.forEach(btn => btn.addEventListener('click', closeMenu));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  window.addEventListener('resize', () => {
    if (isOpen()) closeMenu();
  });
</script>
