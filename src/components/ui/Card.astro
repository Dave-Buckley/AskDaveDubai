---
interface Props {
  href?: string;
  class?: string;
  animate?: boolean;
}
const { href, class: className, animate = true } = Astro.props;
const Tag = href ? 'a' : 'div';
---
<Tag
  href={href}
  class:list={[
    'block bg-paper border border-border p-8 transition-all duration-500 card-glow',
    'hover:shadow-2xl hover:-translate-y-1 hover:border-accent/30',
    href ? 'cursor-pointer' : '',
    className,
  ]}
  data-animate={animate ? '' : undefined}
>
  <slot />
</Tag>
