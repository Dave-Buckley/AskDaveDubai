---
interface Props {
  heading: string;
  subheading?: string;
  imageSrc?: string;
  imageAlt?: string;
}
const { heading, subheading, imageSrc, imageAlt = 'Dubai skyline' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-ink">
  <!-- Background image -->
  {imageSrc && (
    <div class="absolute inset-0 z-0">
      <img
        src={imageSrc}
        alt={imageAlt}
        class="w-full h-full object-cover opacity-30"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/70 via-ink/30 to-ink/90"></div>
    </div>
  )}
  {!imageSrc && (
    <div class="absolute inset-0 z-0 bg-gradient-to-br from-ink via-ink-muted to-ink/90"></div>
  )}

  <!-- Decorative accent lines -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Photo -->
    <div class="w-28 h-28 sm:w-32 sm:h-32 rounded-full border-2 border-accent/40 bg-white/5 mx-auto mb-6 flex items-center justify-center overflow-hidden">
      <img src={`${base}images/dave-closeup.jpg`} alt="Dave Buckley" class="w-full h-full object-cover object-top" />
    </div>

    <!-- RERA badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 border border-accent/30 mb-8">
      <div class="w-2 h-2 rounded-full bg-accent"></div>
      <span class="text-xs tracking-[0.2em] uppercase text-accent font-medium">RERA Certified Broker</span>
    </div>

    <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold text-paper leading-none tracking-tight">
      {heading}
    </h1>
    {subheading && (
      <p class="mt-8 text-lg sm:text-xl text-paper/70 max-w-2xl mx-auto leading-relaxed">
        {subheading}
      </p>
    )}
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <slot name="cta" />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] tracking-[0.3em] uppercase text-paper/30">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-paper/30 to-transparent animate-pulse"></div>
    </div>
  </div>
</section>
