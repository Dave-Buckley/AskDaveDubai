---
import type { CollectionEntry } from 'astro:content';
import ReadingTime from './ReadingTime.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;

const categoryLabels: Record<string, string> = {
  'buying-guide': 'Buying Guide',
  'market-update': 'Market Update',
  'area-insight': 'Area Insight',
  'investment': 'Investment',
  'legal': 'Legal',
  'lifestyle': 'Lifestyle',
};

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  month: 'long',
  year: 'numeric',
}).format(post.data.publishDate);
---
<article
  class="blog-card group flex flex-col bg-white border border-[var(--color-border)] rounded-lg overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
  data-category={post.data.category}
>
  {post.data.heroImage && (
    <a href={`/blog/${post.slug}`} class="block overflow-hidden aspect-[16/9]">
      <img
        src={post.data.heroImage}
        alt={post.data.heroImageAlt || post.data.title}
        width={640}
        height={360}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    </a>
  )}
  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-block px-2.5 py-0.5 text-xs font-medium uppercase tracking-wider bg-[var(--color-paper-muted)] text-[var(--color-ink-muted)] rounded">
        {categoryLabels[post.data.category] || post.data.category}
      </span>
    </div>
    <h3 class="font-heading text-xl font-semibold text-[var(--color-ink)] mb-2 leading-tight">
      <a href={`/blog/${post.slug}`} class="hover:text-[var(--color-accent)] transition-colors">
        {post.data.title}
      </a>
    </h3>
    <p class="text-[var(--color-ink-muted)] text-sm leading-relaxed mb-4 flex-1">
      {post.data.description}
    </p>
    <div class="flex items-center justify-between text-xs text-[var(--color-ink-muted)] mt-auto pt-3 border-t border-[var(--color-border)]">
      <span>{post.data.author}</span>
      <div class="flex items-center gap-3">
        {post.data.readingTime && <ReadingTime minutes={post.data.readingTime} />}
        <time datetime={post.data.publishDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </div>
</article>
