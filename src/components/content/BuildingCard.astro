---
import type { CollectionEntry } from 'astro:content';

interface Props {
  building: CollectionEntry<'buildings'>;
}
const { building } = Astro.props;
---
<article class="group flex flex-col bg-white border border-[var(--color-border)] overflow-hidden transition-all duration-500 card-glow hover:shadow-2xl hover:-translate-y-1 hover:border-[var(--color-accent)]/30">
  <a href={`/buildings/${building.data.slug ?? building.id}`} class="block relative">
    <div class="relative h-52 overflow-hidden">
      <img
        src={building.data.heroImage}
        alt={building.data.heroImageAlt}
        width={600}
        height={400}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-4">
        <h3 class="font-heading text-xl font-bold text-white leading-tight group-hover:text-[var(--color-accent)] transition-colors duration-300">{building.data.name}</h3>
        <p class="text-white/60 text-xs mt-1 tracking-wide">{building.data.developer} &middot; {building.data.completionYear}</p>
      </div>
      {building.data.branded && (
        <span class="absolute top-3 right-3 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider bg-[var(--color-accent)] text-[var(--color-ink)]">
          Hotel-Branded
        </span>
      )}
    </div>
  </a>

  <div class="p-5 flex flex-col flex-1">
    <p class="text-sm text-[var(--color-ink-muted)] mb-4 leading-relaxed line-clamp-2">{building.data.tagline}</p>

    <div class="grid grid-cols-2 gap-3 text-xs mb-4">
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] tracking-[0.1em] uppercase text-[var(--color-ink-muted)]/60">Price/sqft</span>
        <span class="font-semibold text-[var(--color-ink)]">{building.data.avgPricePerSqft}</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] tracking-[0.1em] uppercase text-[var(--color-ink-muted)]/60">Service Charge</span>
        <span class="font-semibold text-[var(--color-ink)]">{building.data.serviceCharge}</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] tracking-[0.1em] uppercase text-[var(--color-ink-muted)]/60">Floors</span>
        <span class="font-semibold text-[var(--color-ink)]">{building.data.floors}</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] tracking-[0.1em] uppercase text-[var(--color-ink-muted)]/60">Holiday Home</span>
        <span class:list={[
          "font-semibold",
          building.data.holidayHome === 'yes' ? 'text-green-600' :
          building.data.holidayHome === 'no' ? 'text-red-600' :
          'text-amber-600'
        ]}>
          {building.data.holidayHome === 'yes' ? 'Allowed' : building.data.holidayHome === 'no' ? 'No' : 'Check'}
        </span>
      </div>
    </div>

    <div class="flex flex-wrap gap-1.5 mt-auto pt-4 border-t border-[var(--color-border)]">
      {building.data.unitTypes.map((type) => (
        <span class="px-2 py-0.5 text-[10px] font-medium bg-[var(--color-paper-muted)] text-[var(--color-ink-muted)] border border-[var(--color-border)]">
          {type}
        </span>
      ))}
      <span class="ml-auto text-[10px] font-medium text-[var(--color-accent)] flex items-center gap-1 group-hover:gap-2 transition-all duration-300">
        View Profile
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</article>
