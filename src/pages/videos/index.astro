---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout
  title="Dubai Property Videos | Watch Expert Insights by Dave Bhatt"
  description="Watch Dave Bhatt's expert market insights on YouTube and TikTok — Dubai property market updates, area tours, buying tips and investment analysis."
>
  <section class="pt-16 pb-16 px-4 max-w-7xl mx-auto">
    <div class="mb-4" data-animate>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-[var(--color-ink)] mb-4">
        Dubai Property Videos
      </h1>
      <p class="text-lg text-[var(--color-ink-muted)] max-w-2xl mb-4">
        Watch Dave's expert market insights on YouTube and TikTok.
      </p>
      <p class="text-sm text-[var(--color-ink-muted)]">
        New videos added regularly.
        <!-- TODO: replace with real YouTube channel URL -->
        <a href="https://youtube.com/@askdavedowntown" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline ml-1">
          Subscribe to Dave's YouTube channel
        </a>
      </p>
    </div>

    <!-- YouTube Section -->
    <div class="mb-16" data-animate>
      <div class="flex items-center gap-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        <h2 class="font-heading text-2xl font-semibold text-[var(--color-ink)]">YouTube</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- TODO: replace with real video IDs -->
        {['VIDEO_ID_1', 'VIDEO_ID_2', 'VIDEO_ID_3'].map((videoId) => (
          <div class="aspect-video bg-[var(--color-paper-muted)] rounded-lg overflow-hidden border border-[var(--color-border)]">
            <!-- TODO: replace VIDEO_ID_1/2/3 with real YouTube video IDs -->
            <iframe
              src={`https://www.youtube.com/embed/${videoId}`}
              title="Dubai property video by Dave Bhatt"
              width="100%"
              height="100%"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
              class="w-full h-full"
            ></iframe>
          </div>
        ))}
      </div>
    </div>

    <!-- TikTok Section -->
    <div data-animate>
      <div class="flex items-center gap-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-[#010101]" aria-hidden="true">
          <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
        </svg>
        <h2 class="font-heading text-2xl font-semibold text-[var(--color-ink)]">TikTok</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- TODO: replace with real TikTok video URLs and IDs -->
        {[
          { videoId: 'TIKTOK_VIDEO_ID_1', username: 'askdavedowntown' },
          { videoId: 'TIKTOK_VIDEO_ID_2', username: 'askdavedowntown' },
          { videoId: 'TIKTOK_VIDEO_ID_3', username: 'askdavedowntown' },
        ].map(({ videoId, username }) => (
          <div class="flex justify-center">
            <!-- TODO: replace TIKTOK_VIDEO_ID_1/2/3 with real TikTok video IDs -->
            <blockquote
              class="tiktok-embed"
              cite={`https://www.tiktok.com/@${username}/video/${videoId}`}
              data-video-id={videoId}
              style="max-width: 325px; min-width: 325px;"
            >
              <section>
                <a
                  href={`https://www.tiktok.com/@${username}/video/${videoId}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-[var(--color-accent)] hover:underline"
                >
                  View on TikTok
                </a>
              </section>
            </blockquote>
          </div>
        ))}
      </div>
      <!-- TikTok embed script -->
      <script async src="https://www.tiktok.com/embed.js"></script>
    </div>
  </section>
</PageLayout>
