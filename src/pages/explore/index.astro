---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import ExploreMap from '../../components/map/ExploreMap';
---
<PageLayout
  title="Explore Downtown Dubai - Interactive Neighbourhood Maps | AskDaveDowntown"
  description="Explore everything near Downtown Dubai with interactive maps. Find restaurants, schools, healthcare, gyms, supermarkets, parks, transport, and shopping - all within 15 minutes of Downtown."
>
  <Section dark class="py-8">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 border border-accent/30 mb-6">
        <div class="w-2 h-2 rounded-full bg-accent"></div>
        <span class="text-xs tracking-[0.2em] uppercase text-accent font-medium">Neighbourhood Guide</span>
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-paper leading-none">
        Explore Downtown Dubai
      </h1>
      <p class="mt-4 text-paper/50 leading-relaxed text-sm">
        See what's around before you move. Eight categories covering everything a tenant needs. All premium options within 15 minutes of Downtown.
      </p>
    </div>
  </Section>

  <section class="px-4 sm:px-6 lg:px-8 pb-8 max-w-[1400px] mx-auto">
    <ExploreMap client:idle />
  </section>

  <Section dark class="py-12">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12" data-animate>
      <a href="/compare" class="group flex items-start gap-4 p-6 border border-white/10 hover:border-accent/30 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-300">
        <div class="w-10 h-10 border border-accent/30 flex items-center justify-center flex-shrink-0 group-hover:border-accent/60 transition-colors">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-paper group-hover:text-accent transition-colors">Compare Areas</h3>
          <p class="text-xs text-paper/40 mt-1">Side-by-side comparison of Dubai areas with stats, pros, and cons.</p>
        </div>
      </a>
      <a href="/area-finder" class="group flex items-start gap-4 p-6 border border-white/10 hover:border-accent/30 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-300">
        <div class="w-10 h-10 border border-accent/30 flex items-center justify-center flex-shrink-0 group-hover:border-accent/60 transition-colors">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-paper group-hover:text-accent transition-colors">Area Finder</h3>
          <p class="text-xs text-paper/40 mt-1">Filter by budget, property type, and lifestyle to find your ideal area.</p>
        </div>
      </a>
    </div>

    <div class="text-center max-w-2xl mx-auto" data-animate>
      <h2 class="font-heading text-2xl font-bold text-paper mb-3">Want to Know More About Living Here?</h2>
      <p class="text-paper/50 text-sm mb-6">I can answer any questions about day-to-day life in Downtown Dubai - commute times, community vibe, hidden gems.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://wa.me/971503019926?text=Hi%20Dave%2C%20I%27m%20interested%20in%20living%20in%20Downtown%20Dubai"
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366] text-white text-sm font-semibold hover:bg-[#20BD5A] transition-colors duration-200">
          Ask Dave on WhatsApp
        </a>
        <a href="mailto:dave.buckley@paragonproperties.ae?subject=Downtown%20Dubai%20Enquiry"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-accent/40 text-accent text-sm font-semibold hover:bg-accent/10 transition-colors duration-200">
          Email Dave
        </a>
      </div>
    </div>
  </Section>
</PageLayout>
