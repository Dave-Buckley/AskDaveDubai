---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import FitnessMap from '../../components/map/FitnessMap';
---
<PageLayout
  title="Gyms & Fitness Near Downtown Dubai - Interactive Map | AskDaveDowntown"
  description="Find gyms, yoga studios, swimming pools, and spas near Downtown Dubai. From budget gyms to boutique fitness studios - all within 15 minutes."
>
  <Section dark class="py-12">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 border border-accent/30 mb-6">
        <div class="w-2 h-2 rounded-full bg-accent"></div>
        <span class="text-xs tracking-[0.2em] uppercase text-accent font-medium">Fitness & Wellness</span>
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-paper leading-none">
        Fitness & Wellness
      </h1>
      <p class="mt-4 text-paper/50 leading-relaxed text-sm">
        Gyms, yoga studios, pools, spas, and sports facilities within 15 minutes of Downtown Dubai. From AED 99/mo budget gyms to boutique studios.
      </p>
      <a href="/explore" class="inline-flex items-center gap-1 mt-4 text-accent/60 text-xs hover:text-accent transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
        All Explore Maps
      </a>
    </div>
  </Section>

  <section class="px-4 sm:px-6 lg:px-8 pb-8 max-w-[1400px] mx-auto">
    <FitnessMap client:visible />
  </section>

  <Section dark class="py-12">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <h2 class="font-heading text-2xl font-bold text-paper mb-3">Looking for Fitness Options Near a Specific Building?</h2>
      <p class="text-paper/50 text-sm mb-6">Some Downtown buildings have their own gyms and pools. I can tell you what facilities your building includes and what is nearby.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://wa.me/971503019926?text=Hi%20Dave%2C%20what%20gym%20options%20are%20there%20near%20Downtown%20Dubai%3F"
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366] text-white text-sm font-semibold hover:bg-[#20BD5A] transition-colors duration-200">
          Ask Dave on WhatsApp
        </a>
        <a href="mailto:dave.buckley@paragonproperties.ae?subject=Fitness%20Near%20Downtown"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-accent/40 text-accent text-sm font-semibold hover:bg-accent/10 transition-colors duration-200">
          Email Dave
        </a>
      </div>
    </div>
  </Section>
</PageLayout>
