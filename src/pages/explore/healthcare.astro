---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import HealthcareMap from '../../components/map/HealthcareMap';
const base = import.meta.env.BASE_URL;
---
<PageLayout
  title="Healthcare Near Downtown Dubai - Hospitals, Clinics & Dentists Map | AskDaveDowntown"
  description="Find hospitals, clinics, dental practices, and pharmacies near Downtown Dubai. Premium healthcare options mapped with drive times and Google Maps links."
>
  <Section dark class="py-12">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 border border-accent/30 mb-6">
        <div class="w-2 h-2 rounded-full bg-accent"></div>
        <span class="text-xs tracking-[0.2em] uppercase text-accent font-medium">Healthcare</span>
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-paper leading-none">
        Healthcare & Medical
      </h1>
      <p class="mt-4 text-paper/50 leading-relaxed text-sm">
        Hospitals, GP clinics, dental practices, and pharmacies within 15 minutes of Downtown Dubai. Including UK-affiliated and premium private options.
      </p>
      <a href={`${base}explore`} class="inline-flex items-center gap-1 mt-4 text-accent/60 text-xs hover:text-accent transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
        All Explore Maps
      </a>
    </div>
  </Section>

  <section class="px-4 sm:px-6 lg:px-8 pb-8 max-w-[1400px] mx-auto">
    <HealthcareMap client:visible />
  </section>

  <Section dark class="py-12">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <h2 class="font-heading text-2xl font-bold text-paper mb-3">Questions About Healthcare in Dubai?</h2>
      <p class="text-paper/50 text-sm mb-6">Health insurance, finding a GP, and understanding the healthcare system are common concerns for new arrivals. Happy to point you in the right direction.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://wa.me/971503019926?text=Hi%20Dave%2C%20I%20have%20questions%20about%20healthcare%20near%20Downtown%20Dubai"
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366] text-white text-sm font-semibold hover:bg-[#20BD5A] transition-colors duration-200">
          Ask Dave on WhatsApp
        </a>
        <a href="mailto:dave.buckley@paragonproperties.ae?subject=Healthcare%20in%20Dubai"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-accent/40 text-accent text-sm font-semibold hover:bg-accent/10 transition-colors duration-200">
          Email Dave
        </a>
      </div>
    </div>
  </Section>
</PageLayout>
