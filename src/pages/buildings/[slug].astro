---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import AuthorBio from '../../components/content/AuthorBio.astro';

export async function getStaticPaths() {
  const buildings = await getCollection('buildings');
  return buildings.map((building) => ({
    params: { slug: building.slug },
    props: { building },
  }));
}

const { building } = Astro.props;
const base = import.meta.env.BASE_URL;
const { Content } = await building.render();

const whatsappMessage = encodeURIComponent(`Hi Dave, I'm interested in ${building.data.name} in Downtown Dubai. Can you help?`);
const whatsappUrl = `https://wa.me/971503019926?text=${whatsappMessage}`;

const holidayLabels: Record<string, { text: string; color: string }> = {
  yes: { text: 'Allowed', color: 'bg-green-100 text-green-700' },
  no: { text: 'Not Allowed', color: 'bg-red-100 text-red-700' },
  check: { text: 'Check with Management', color: 'bg-amber-100 text-amber-700' },
};
const holidayInfo = holidayLabels[building.data.holidayHome] || holidayLabels.check;
---
<PageLayout
  title={`${building.data.name} | Downtown Dubai Building Guide | AskDaveDowntown`}
  description={building.data.metaDescription}
  ogImage={building.data.heroImage}
>
  <!-- Full-width hero -->
  <div class="relative h-64 md:h-96 overflow-hidden">
    <img
      src={building.data.heroImage}
      alt={building.data.heroImageAlt}
      width={1440}
      height={600}
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 px-6 pb-8 max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-2">
        {building.data.branded && (
          <span class="px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider bg-[var(--color-accent)] text-[var(--color-ink)] rounded">
            Hotel-Branded
          </span>
        )}
        {building.data.developerUrl ? (
          <a href={building.data.developerUrl} target="_blank" rel="noopener noreferrer" class="text-white/70 text-sm hover:text-white transition-colors">by {building.data.developer} &#8599;</a>
        ) : (
          <span class="text-white/70 text-sm">by {building.data.developer}</span>
        )}
      </div>
      <h1 class="font-heading text-3xl md:text-5xl font-bold text-white mb-2">{building.data.name}</h1>
      <p class="text-white/85 text-lg">{building.data.tagline}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">
      <!-- Main Content -->
      <div>
        <!-- Highlights -->
        {building.data.highlights && building.data.highlights.length > 0 && (
          <div class="mb-8 p-5 bg-[var(--color-paper-muted)] rounded-lg border border-[var(--color-border)]">
            <h2 class="font-heading text-xl font-semibold text-[var(--color-ink)] mb-3">Building Highlights</h2>
            <ul class="grid sm:grid-cols-2 gap-2">
              {building.data.highlights.map((highlight) => (
                <li class="flex items-start gap-2 text-sm text-[var(--color-ink-muted)]">
                  <span class="text-[var(--color-accent)] mt-0.5" aria-hidden="true">&#9733;</span>
                  {highlight}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Markdown body -->
        <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-[var(--color-ink)] prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline mb-10">
          <Content />
        </div>

        <!-- Location & Street View -->
        {building.data.location && (
          <section class="mb-10">
            <h2 class="font-heading text-2xl font-semibold text-[var(--color-ink)] mb-4">Location</h2>
            <div class="rounded-lg overflow-hidden border border-[var(--color-border)]">
              <iframe
                src={`https://maps.google.com/maps?q=${building.data.location.lat},${building.data.location.lng}&z=17&output=embed`}
                width="100%"
                height="350"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Map showing ${building.data.name} location`}
              ></iframe>
            </div>
            <div class="mt-3 flex flex-wrap gap-3">
              <a
                href={`https://www.google.com/maps/@?api=1&map_action=pano&viewpoint=${building.data.location.lat},${building.data.location.lng}&heading=${building.data.location.heading}&pitch=10&fov=80`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-paper-muted)] text-[var(--color-ink)] text-sm font-medium rounded-lg border border-[var(--color-border)] hover:border-[var(--color-ink)] transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                Open Google Street View
              </a>
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${building.data.location.lat},${building.data.location.lng}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 text-sm text-[var(--color-accent)] hover:underline"
              >
                Get Directions
              </a>
            </div>
          </section>
        )}

        <!-- Bottom CTA -->
        <div class="mt-12 p-6 bg-[var(--color-ink)] text-[var(--color-paper)] rounded-xl text-center">
          <p class="font-heading text-xl font-semibold mb-2">Interested in {building.data.name}?</p>
          <p class="text-[var(--color-paper)]/75 text-sm mb-4">I can pull current listings, recent transactions, and give you an honest view on this building.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366] text-white font-medium rounded-lg hover:bg-[#1da851] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Dave
            </a>
            <a
              href={`mailto:dave.buckley@paragonproperties.ae?subject=${encodeURIComponent(building.data.name)} enquiry`}
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 text-white font-medium rounded-lg hover:bg-white/20 transition-colors"
            >
              Email Dave
            </a>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-8 lg:self-start space-y-6">
        <div class="p-5 bg-white border border-[var(--color-border)] rounded-xl shadow-sm">
          <h2 class="font-heading text-lg font-semibold text-[var(--color-ink)] mb-4">Key Stats</h2>
          <dl class="space-y-3">
            <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
              <dt class="text-sm text-[var(--color-ink-muted)]">Developer</dt>
              <dd class="text-sm font-medium text-right">
                {building.data.developerUrl ? (
                  <a href={building.data.developerUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">{building.data.developer}</a>
                ) : (
                  <span class="text-[var(--color-ink)]">{building.data.developer}</span>
                )}
              </dd>
            </div>
            <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
              <dt class="text-sm text-[var(--color-ink-muted)]">Completed</dt>
              <dd class="text-sm font-medium text-[var(--color-ink)] text-right">{building.data.completionYear}</dd>
            </div>
            <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
              <dt class="text-sm text-[var(--color-ink-muted)]">Floors</dt>
              <dd class="text-sm font-medium text-[var(--color-ink)] text-right">{building.data.floors}</dd>
            </div>
            {building.data.totalUnits && (
              <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
                <dt class="text-sm text-[var(--color-ink-muted)]">Total Units</dt>
                <dd class="text-sm font-medium text-[var(--color-ink)] text-right">{building.data.totalUnits}</dd>
              </div>
            )}
            <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
              <dt class="text-sm text-[var(--color-ink-muted)]">Avg Price/sqft</dt>
              <dd class="text-sm font-medium text-[var(--color-ink)] text-right">{building.data.avgPricePerSqft}</dd>
            </div>
            <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
              <dt class="text-sm text-[var(--color-ink-muted)]">Service Charge</dt>
              <dd class="text-sm font-medium text-[var(--color-ink)] text-right">{building.data.serviceCharge}</dd>
            </div>
            {building.data.branded && building.data.brandName && (
              <div class="flex justify-between items-start py-2 border-b border-[var(--color-border)]">
                <dt class="text-sm text-[var(--color-ink-muted)]">Brand</dt>
                <dd class="text-sm font-medium text-[var(--color-ink)] text-right">{building.data.brandName}</dd>
              </div>
            )}
            <div class="flex justify-between items-center py-2 border-b border-[var(--color-border)]">
              <dt class="text-sm text-[var(--color-ink-muted)]">Holiday Homes</dt>
              <dd>
                <span class={`px-2 py-0.5 text-xs font-medium rounded ${holidayInfo.color}`}>
                  {holidayInfo.text}
                </span>
              </dd>
            </div>
            <div class="flex justify-between items-center py-2">
              <dt class="text-sm text-[var(--color-ink-muted)]">Serviced</dt>
              <dd>
                {building.data.serviced ? (
                  <span class="px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700 rounded">Yes</span>
                ) : (
                  <span class="px-2 py-0.5 text-xs font-medium bg-[var(--color-paper-muted)] text-[var(--color-ink-muted)] rounded">No</span>
                )}
              </dd>
            </div>
          </dl>
        </div>

        <div class="p-5 bg-white border border-[var(--color-border)] rounded-xl shadow-sm">
          <h2 class="font-heading text-lg font-semibold text-[var(--color-ink)] mb-3">Unit Types</h2>
          <div class="flex flex-wrap gap-2">
            {building.data.unitTypes.map((type) => (
              <span class="px-3 py-1 text-sm bg-[var(--color-paper-muted)] text-[var(--color-ink-muted)] rounded-full border border-[var(--color-border)]">
                {type}
              </span>
            ))}
          </div>
        </div>

        <a
          href={`${base}buildings`}
          class="block text-center text-sm text-[var(--color-accent)] hover:underline"
        >
          View all Downtown buildings
        </a>

        <AuthorBio />
      </aside>
    </div>
  </div>
</PageLayout>
