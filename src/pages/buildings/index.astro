---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BuildingCard from '../../components/content/BuildingCard.astro';
import BuildingsMap from '../../components/map/BuildingsMap';
import Section from '../../components/ui/Section.astro';

const allBuildings = await getCollection('buildings');
const buildings = allBuildings.sort((a, b) => a.data.order - b.data.order);

const branded = buildings.filter(b => b.data.branded).sort((a, b) => a.data.name.localeCompare(b.data.name));
const residential = buildings.filter(b => !b.data.branded).sort((a, b) => a.data.name.localeCompare(b.data.name));

const totalBuildings = buildings.length;
const totalBranded = branded.length;

const mapBuildings = buildings
  .filter(b => b.data.location)
  .map(b => ({
    name: b.data.name,
    slug: b.slug,
    lat: b.data.location!.lat,
    lng: b.data.location!.lng,
    branded: b.data.branded,
    brandName: b.data.brandName,
    tagline: b.data.tagline,
  }));
---
<PageLayout
  title="Downtown Dubai Buildings Guide | AskDaveDowntown"
  description="Profiles of residential buildings in Downtown Dubai. Developer info, unit types, and key details for each building. Get in touch for pricing and availability."
  ogImage="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1200&q=80&auto=format"
>
  <!-- Hero -->
  <div class="relative overflow-hidden bg-ink">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1920&q=80&auto=format"
        alt="Downtown Dubai skyline with Burj Khalifa"
        class="w-full h-full object-cover opacity-25"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/60 via-ink/40 to-ink"></div>
    </div>
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 border border-accent/30 mb-8" data-animate>
        <div class="w-2 h-2 rounded-full bg-accent"></div>
        <span class="text-xs tracking-[0.2em] uppercase text-accent font-medium">Downtown Dubai Specialist</span>
      </div>

      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-paper leading-none mb-6" data-animate>
        Downtown Dubai<br/><span class="text-gradient-gold">Building Profiles.</span>
      </h1>

      <p class="text-lg text-paper/60 max-w-2xl leading-relaxed mb-10" data-animate>
        An introduction to each building in Downtown Dubai. Get in touch for current pricing, service charges, and availability.
      </p>

      <!-- Quick stats -->
      <div class="grid grid-cols-3 gap-px bg-paper/10 max-w-lg" data-animate>
        <div class="bg-ink p-4 text-center">
          <p class="font-heading text-2xl font-bold text-accent">{totalBuildings}</p>
          <p class="text-[10px] tracking-[0.15em] uppercase text-paper/40 mt-1">Buildings</p>
        </div>
        <div class="bg-ink p-4 text-center">
          <p class="font-heading text-2xl font-bold text-accent">{totalBranded}</p>
          <p class="text-[10px] tracking-[0.15em] uppercase text-paper/40 mt-1">Hotel-Branded</p>
        </div>
        <div class="bg-ink p-4 text-center">
          <p class="font-heading text-2xl font-bold text-accent">{totalBuildings - totalBranded}</p>
          <p class="text-[10px] tracking-[0.15em] uppercase text-paper/40 mt-1">Residential</p>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  </div>

  <!-- Buildings Map - DISABLED: GPS spoofing from regional conflict makes map coords unreliable
  <section class="bg-ink px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6" data-animate>
        <div class="w-8 h-px bg-accent"></div>
        <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold">Interactive Map</p>
      </div>
      <BuildingsMap buildings={mapBuildings} client:visible />
    </div>
  </section>
  -->

  <!-- Hotel-Branded Residences -->
  {branded.length > 0 && (
    <Section>
      <div class="mb-10" data-animate>
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-px bg-accent"></div>
          <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold">Premium</p>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3">
          Hotel-Branded Residences
        </h2>
        <p class="text-[var(--color-ink-muted)] max-w-2xl">
          Managed by Address Hotels + Resorts or Vida Hotels. Full hotel services and strong short-term rental demand.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
        {branded.map((building) => (
          <div data-animate>
            <BuildingCard building={building} />
          </div>
        ))}
      </div>
    </Section>
  )}

  <div class="gold-line"></div>

  <!-- Residential Towers -->
  {residential.length > 0 && (
    <Section>
      <div class="mb-10" data-animate>
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-px bg-accent"></div>
          <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold">Residential</p>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3">
          Residential Towers
        </h2>
        <p class="text-[var(--color-ink-muted)] max-w-2xl">
          Standard residential buildings with more owner-occupiers and a range of unit types. From established towers to newer high-rises.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
        {residential.map((building) => (
          <div data-animate>
            <BuildingCard building={building} />
          </div>
        ))}
      </div>
    </Section>
  )}

  <!-- CTA -->
  <Section dark>
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">Get Advice</p>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-paper leading-tight mb-4">
        Not Sure Which Building<br/>Is Right for You?
      </h2>
      <p class="text-paper/50 text-sm leading-relaxed mb-8">
        Tell me your budget, priorities, and whether you are buying to live or invest. I will shortlist the buildings that actually make sense for you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/971503019926?text=Hi%20Dave%2C%20I%27m%20looking%20at%20buildings%20in%20Downtown%20Dubai%20and%20need%20your%20advice"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#25D366] text-white font-medium rounded-lg hover:bg-[#1da851] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Dave
        </a>
        <a
          href="mailto:dave.buckley@paragonproperties.ae?subject=Downtown Dubai building advice"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-paper/20 text-paper font-medium rounded-lg hover:bg-paper hover:text-ink transition-all"
        >
          Email Dave
        </a>
      </div>
    </div>
  </Section>
</PageLayout>
