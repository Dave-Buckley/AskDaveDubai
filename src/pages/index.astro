---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const featuredContent = [
  {
    title: 'Downtown Dubai',
    description: 'Why Downtown is the best address in the city - restaurants, lifestyle, investment.',
    href: `${base}downtown`,
    tag: 'Discover',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
  },
  {
    title: 'Ask Dave Q&A',
    description: 'Honest, transparent answers to the most common Dubai property questions.',
    href: `${base}ask-dave`,
    tag: 'Learn',
    icon: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01',
  },
  {
    title: 'Buyer Guides',
    description: 'Step-by-step guides to buying, costs, visas, and more.',
    href: `${base}guides`,
    tag: 'Guide',
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  },
];

const processSteps = [
  {
    step: '01',
    title: 'Discovery Call',
    description: 'We start with a no-pressure conversation about your goals, budget, and timeline.',
  },
  {
    step: '02',
    title: 'Curated Shortlist',
    description: 'I hand-pick properties that match your criteria - whether buying or renting. No spam, no irrelevant listings.',
  },
  {
    step: '03',
    title: 'Viewings & Analysis',
    description: 'We tour the shortlisted properties together. I share honest insights on each one.',
  },
  {
    step: '04',
    title: 'Negotiate & Close',
    description: 'I handle negotiations and paperwork - you just sign and collect keys.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AskDaveDowntown - Dubai Real Estate Expert",
  "url": "https://askdavedowntown.com",
  "description": "Dubai real estate guidance from a RERA-certified broker. Practical area guides, buyer resources, and direct access to Dave."
};
---
<PageLayout
  title="AskDaveDowntown - Dubai Real Estate Expert"
  description="Dubai real estate guidance from a RERA-certified broker. Buy, invest, rent, or explore Dubai property. Book a free consultation."
  schema={schema}
>
  <!-- HERO -->
  <Hero
    heading="Your Dubai Property Expert"
    subheading="Honest, transparent property advice from a RERA-certified broker with firsthand experience of how the UAE market operates, having lived and worked here for over 8 years."
    imageSrc="https://images.unsplash.com/photo-1748626083682-611d0a66cb50?w=1920&q=80&auto=format"
    imageAlt="Dubai skyline at dusk"
  >
    <Fragment slot="cta">
      <a
        href="https://wa.me/971503019926"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-medium tracking-wide bg-[#25D366] text-white hover:bg-[#1da851] transition-all duration-200 rounded-lg"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Dave Now
      </a>
      <Button href={`${base}contact`} variant="secondary" size="lg" class="border-paper text-paper hover:bg-paper hover:text-ink">
        Book a Free Call
      </Button>
    </Fragment>
  </Hero>

  <!-- GOLD DIVIDER -->
  <div class="gold-line"></div>

  <!-- VALUE PROPOSITION -->
  <Section>
    <div class="text-center max-w-3xl mx-auto mb-16" data-animate>
      <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">Why Dave?</p>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold text-ink leading-tight">
        Real Expertise.<br/><span class="text-gradient-gold">Real Answers.</span>
      </h2>
      <p class="mt-6 text-ink-muted leading-relaxed max-w-xl mx-auto">
        Dubai's property market moves fast and there is a lot of noise. I cut through it. Whether you are buying your first apartment or building an investment portfolio, I will walk you through every step with honest, no-strings-attached guidance.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-stagger>
      {featuredContent.map(item => (
        <Card href={item.href} animate>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full border border-accent/30 flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold">{item.tag}</p>
          </div>
          <h3 class="font-heading text-2xl font-bold text-ink mb-3">{item.title}</h3>
          <p class="text-ink-muted text-sm leading-relaxed">{item.description}</p>
          <div class="mt-6 text-sm font-medium text-accent flex items-center gap-2">
            Explore
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </Card>
      ))}
    </div>
  </Section>

  <!-- HOW I WORK -->
  <Section dark>
    <div class="text-center mb-16" data-animate>
      <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">The Process</p>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold text-paper leading-tight">
        How I Work With Clients
      </h2>
      <p class="mt-4 text-paper/60 max-w-xl mx-auto">
        A straightforward, transparent process from first conversation to keys in hand.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-paper/10" data-stagger>
      {processSteps.map((item) => (
        <div class="bg-ink p-8 relative" data-animate>
          <span class="font-heading text-5xl font-bold text-accent/15 absolute top-4 right-6">{item.step}</span>
          <div class="relative">
            <p class="text-accent text-xs tracking-[0.2em] uppercase font-semibold mb-3">Step {item.step}</p>
            <h3 class="font-heading text-xl font-bold text-paper mb-3">{item.title}</h3>
            <p class="text-paper/60 text-sm leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- DOWNTOWN DUBAI MARKET SNAPSHOT -->
  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div data-animate>
        <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">Market Intelligence</p>
        <h2 class="font-heading text-4xl sm:text-5xl font-bold text-ink leading-tight mb-6">
          Downtown Dubai<br/>Market Snapshot
        </h2>
        <p class="text-ink-muted leading-relaxed mb-8">
          Downtown Dubai remains the city's most iconic address - anchored by Burj Khalifa and Dubai Mall. It consistently ranks in the top areas for secondary transactions, reflecting strong liquidity and lifestyle appeal.
        </p>
        <Button href={`${base}downtown`} variant="primary">Discover Downtown Dubai</Button>
      </div>

      <div class="grid grid-cols-2 gap-4" data-stagger>
        <div class="border border-border p-6" data-animate>
          <p class="font-heading text-3xl font-bold text-ink">5.5-6.5%</p>
          <p class="text-xs text-ink-muted mt-1 tracking-wide uppercase">Gross Rental Yield</p>
        </div>
        <div class="border border-border p-6" data-animate>
          <p class="font-heading text-3xl font-bold text-ink">Top 5</p>
          <p class="text-xs text-ink-muted mt-1 tracking-wide uppercase">Transaction Volume</p>
        </div>
        <div class="border border-border p-6" data-animate>
          <p class="font-heading text-3xl font-bold text-ink">215K+</p>
          <p class="text-xs text-ink-muted mt-1 tracking-wide uppercase">Dubai Sales (2025)</p>
        </div>
        <div class="border border-border p-6" data-animate>
          <p class="font-heading text-3xl font-bold text-ink">+20%</p>
          <p class="text-xs text-ink-muted mt-1 tracking-wide uppercase">YoY Price Growth</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- GOLD DIVIDER -->
  <div class="gold-line"></div>

  <!-- LATEST FROM THE BLOG -->
  <Section dark>
    <div class="text-center mb-12" data-animate>
      <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">Latest Articles</p>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold text-paper">From the Blog</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
      {latestPosts.map(post => (
        <a href={`${base}blog/${post.slug}`} class="block border border-paper/10 p-8 hover:border-accent/30 transition-all duration-500 group" data-animate>
          <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">{post.data.category.replace('-', ' ')}</p>
          <h3 class="font-heading text-xl font-bold text-paper mb-3 leading-tight group-hover:text-accent transition-colors duration-300">{post.data.title}</h3>
          <p class="text-paper/50 text-sm leading-relaxed line-clamp-3">{post.data.description}</p>
          <div class="mt-6 text-sm font-medium text-accent flex items-center gap-2">
            Read more
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-10" data-animate>
      <Button href={`${base}blog`} variant="secondary" class="border-paper text-paper hover:bg-paper hover:text-ink">
        View All Articles
      </Button>
    </div>
  </Section>

  <!-- CTA SECTION -->
  <Section class="py-24">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">Get Started</p>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold text-ink leading-tight">
        Ready to Make Your Move?
      </h2>
      <p class="mt-6 text-ink-muted leading-relaxed">
        You do not need to have all the answers before reaching out. Most of my clients start with a simple question on WhatsApp - and that is all it takes. No obligation, ever.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="https://wa.me/971503019926" variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
          WhatsApp Dave
        </Button>
        <Button href="mailto:dave.buckley@paragonproperties.ae" variant="primary" size="lg">
          Email Dave
        </Button>
      </div>
    </div>
  </Section>
</PageLayout>
