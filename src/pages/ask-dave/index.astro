---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import QACard from '../../components/content/QACard.astro';

const allQA = await getCollection('qa');

const featuredQA = allQA.filter((q) => q.data.featured);
const categoryLabels: Record<string, string> = {
  'buying': 'Buying',
  'visa': 'Visa',
  'legal': 'Legal',
  'mortgage': 'Mortgage',
  'investment': 'Investment',
  'lifestyle': 'Lifestyle',
  'fees': 'Fees',
};

const categories = ['buying', 'visa', 'legal', 'mortgage', 'investment', 'lifestyle', 'fees'] as const;

// Group by category
const grouped = categories.reduce((acc, cat) => {
  const items = allQA.filter((q) => q.data.category === cat);
  if (items.length > 0) {
    acc[cat] = items;
  }
  return acc;
}, {} as Record<string, typeof allQA>);

const whatsappUrl = `https://wa.me/971503019926?text=${encodeURIComponent("Hi Dave, I have a question about buying property in Dubai.")}`;
---
<PageLayout
  title="Ask Dave | Dubai Property FAQ | Dave Buckley"
  description="Expert answers to the most common questions about buying property in Dubai - visas, fees, legal process, mortgages and investment strategy. By RERA-registered agent Dave Buckley."
>
  <section class="pt-16 pb-16 px-4 max-w-7xl mx-auto">
    <div class="mb-10" data-animate>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-[var(--color-ink)] mb-4">
        Ask Dave
      </h1>
      <p class="text-lg text-[var(--color-ink-muted)] max-w-2xl">
        The questions I get asked most by buyers, tenants, and investors. Straight answers, no fluff. If yours is not here, send it over on WhatsApp.
      </p>
    </div>

    <!-- Search -->
    <div class="mb-8" data-animate>
      <div class="relative max-w-xl">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--color-ink-muted)]" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          id="qa-search"
          placeholder="Search questions..."
          class="w-full pl-11 pr-4 py-3 border border-[var(--color-border)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-ink)] focus:border-transparent"
          aria-label="Search questions"
        />
      </div>
    </div>

    <!-- Featured Questions -->
    {featuredQA.length > 0 && (
      <div class="mb-12" data-animate>
        <h2 class="font-heading text-2xl font-semibold text-[var(--color-ink)] mb-6">Top Questions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredQA.map((qa) => (
            <QACard qa={qa} />
          ))}
        </div>
      </div>
    )}

    <!-- Categories -->
    {Object.entries(grouped).map(([cat, items]) => (
      <div class="mb-12" data-animate>
        <h2 class="font-heading text-2xl font-semibold text-[var(--color-ink)] mb-6">
          {categoryLabels[cat] || cat}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {items.map((qa) => (
            <QACard qa={qa} />
          ))}
        </div>
      </div>
    ))}

    {allQA.length === 0 && (
      <div class="text-center py-20 text-[var(--color-ink-muted)]" data-animate>
        <p class="text-lg">Q&A content coming soon.</p>
        <p class="text-sm mt-2">Dave is writing answers to the most common Dubai property questions.</p>
      </div>
    )}

    <!-- CTA -->
    <div class="mt-8 p-6 bg-[var(--color-paper-muted)] rounded-xl border border-[var(--color-border)] text-center" data-animate>
      <p class="font-heading text-xl font-semibold text-[var(--color-ink)] mb-2">Can't find your answer?</p>
      <p class="text-[var(--color-ink-muted)] text-sm mb-4">Ask Dave directly on WhatsApp - he responds to genuine questions.</p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#25D366] text-white font-medium rounded-lg hover:bg-[#1da851] transition-colors"
      >
        Ask Dave on WhatsApp
      </a>
    </div>
  </section>
</PageLayout>

<script>
  const searchInput = document.getElementById('qa-search') as HTMLInputElement;
  const qaCards = document.querySelectorAll<HTMLElement>('.qa-card');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    qaCards.forEach((card) => {
      const question = card.dataset.question || '';
      card.style.display = query === '' || question.includes(query) ? '' : 'none';
    });
  });
</script>
