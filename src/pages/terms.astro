---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
---
<PageLayout
  title="Terms of Use | AskDaveDowntown"
  description="Terms of use for AskDaveDowntown website."
  noindex={true}
>
  <Section>
    <div class="max-w-3xl mx-auto prose prose-lg">
      <h1 class="font-heading text-4xl font-bold text-ink">Terms of Use</h1>
      <p class="text-ink-muted text-sm">Last updated: {new Date().toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</p>

      <h2>Acceptance of Terms</h2>
      <p>By accessing AskDaveDowntown, you agree to these terms. If you do not agree, please do not use this site.</p>

      <h2>Information Disclaimer</h2>
      <p>Content on this site is provided for informational purposes only and does not constitute financial or legal advice. Real estate transactions involve significant financial decisions — always conduct your own due diligence and consult qualified professionals.</p>

      <h2>Calculator Tools</h2>
      <p>The fee calculators and financial tools on this site provide estimates only. Figures are based on standard DLD fee schedules and may not reflect current rates. Always verify fees with the Dubai Land Department or a licensed agent.</p>

      <h2>Intellectual Property</h2>
      <p>All content on this site — text, images, and tools — is the property of AskDaveDowntown. You may not reproduce or distribute content without prior written consent.</p>

      <h2>Limitation of Liability</h2>
      <p>AskDaveDowntown is not liable for any losses arising from reliance on information provided on this site.</p>

      <h2>Contact</h2>
      <p>Questions? Email dave@askdavedowntown.com.</p>
    </div>
  </Section>
</PageLayout>
