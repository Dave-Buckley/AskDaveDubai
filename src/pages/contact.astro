---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
---
<PageLayout
  title="Contact Dave — Book a Dubai Real Estate Consultation | AskDaveDowntown"
  description="Reach out to Dave directly via WhatsApp, contact form, or book a free Calendly consultation. RERA-certified Dubai real estate expert ready to help."
>
  <Section dark>
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <p class="text-xs tracking-widest uppercase text-accent font-semibold mb-3">Get in Touch</p>
      <h1 class="font-heading text-5xl sm:text-6xl font-bold text-paper leading-none">Contact Dave</h1>
      <p class="mt-6 text-paper/70 leading-relaxed">
        Whether you have a quick question or you're ready to start your Dubai property search — reach out. No obligation, no pressure.
      </p>
    </div>
  </Section>

  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Contact Form (Formspree) -->
      <div data-animate>
        <h2 class="font-heading text-3xl font-bold text-ink mb-6">Send a Message</h2>
        <!-- REPLACE: Update action URL with your Formspree endpoint after creating an account at formspree.io -->
        <form action="https://formspree.io/f/REPLACE_WITH_YOUR_ID" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-ink mb-1">Full Name *</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-3 border border-border bg-paper text-ink focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors duration-200"
              placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink mb-1">Email Address *</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-border bg-paper text-ink focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors duration-200"
              placeholder="your@email.com" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-ink mb-1">Phone / WhatsApp</label>
            <input type="tel" id="phone" name="phone"
              class="w-full px-4 py-3 border border-border bg-paper text-ink focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors duration-200"
              placeholder="+1 234 567 8900" />
          </div>
          <div>
            <label for="interest" class="block text-sm font-medium text-ink mb-1">I'm interested in</label>
            <select id="interest" name="interest"
              class="w-full px-4 py-3 border border-border bg-paper text-ink focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors duration-200">
              <option value="">Select an option</option>
              <option value="buying">Buying a property</option>
              <option value="investing">Investment / Buy-to-let</option>
              <option value="off-plan">Off-plan property</option>
              <option value="golden-visa">Golden Visa enquiry</option>
              <option value="general">General question</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-1">Message *</label>
            <textarea id="message" name="message" required rows="4"
              class="w-full px-4 py-3 border border-border bg-paper text-ink focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors duration-200 resize-none"
              placeholder="Tell me what you're looking for..."></textarea>
          </div>
          <button type="submit"
            class="w-full py-4 bg-ink text-paper font-semibold tracking-wide hover:bg-ink-muted transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Details + Calendly + WhatsApp -->
      <div class="space-y-8" data-animate>
        <!-- WhatsApp CTA -->
        <div class="p-6 bg-[#25D366]/10 border border-[#25D366]/30">
          <h3 class="font-heading text-2xl font-bold text-ink mb-2">Prefer WhatsApp?</h3>
          <p class="text-ink-muted text-sm mb-4">98% of my client conversations start on WhatsApp. It's the fastest way to reach me.</p>
          <!-- REPLACE: Update wa.me number with Dave's actual WhatsApp number -->
          <a href="https://wa.me/971XXXXXXXXX?text=Hi%20Dave%2C%20I%27m%20interested%20in%20Dubai%20real%20estate"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-6 py-3 bg-[#25D366] text-white font-semibold hover:bg-[#22c35e] transition-colors duration-200">
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chat on WhatsApp
          </a>
        </div>

        <!-- Book a Consultation (Calendly embed) -->
        <div>
          <h3 class="font-heading text-2xl font-bold text-ink mb-2">Book a Free Consultation</h3>
          <p class="text-ink-muted text-sm mb-4">30 minutes, no obligation. I'll answer your questions and help you figure out your next move.</p>
          <!-- REPLACE: Update src with your Calendly embed URL after creating account -->
          <div class="border border-border overflow-hidden" style="min-height:500px;">
            <iframe
              src="https://calendly.com/REPLACE_WITH_YOUR_USERNAME/30min"
              width="100%"
              height="500"
              frameborder="0"
              title="Book a consultation with Dave"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Direct contact details -->
        <div class="p-6 border border-border">
          <h3 class="font-semibold text-ink mb-4">Direct Contact</h3>
          <ul class="space-y-3 text-sm text-ink-muted">
            <!-- REPLACE: Update with real contact details -->
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:dave@askdavedowntown.com" class="hover:text-accent transition-colors duration-200">dave@askdavedowntown.com</a>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>Downtown Dubai, UAE</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </Section>
</PageLayout>
