---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
const base = import.meta.env.BASE_URL;

const categories = [
  {
    name: 'Everyday Essentials',
    description: 'The apps you will use every single day living in Dubai.',
    apps: [
      {
        name: 'Noon',
        tagline: 'The Amazon of the Middle East',
        description: 'UAE-based online marketplace for electronics, groceries, fashion, and home essentials. Fast delivery (often same-day in Dubai), competitive prices, and regular flash sales. Most residents use Noon Daily for grocery delivery.',
        category: 'Shopping & Delivery',
      },
      {
        name: 'Talabat',
        tagline: 'Food delivery that actually works',
        description: 'The most popular food delivery app in the UAE. Covers restaurants, groceries, pharmacies, and convenience stores. Talabat Mart offers 15-minute grocery delivery in most Dubai areas.',
        category: 'Food Delivery',
      },
      {
        name: 'Careem',
        tagline: 'Ride-hailing, food, and payments',
        description: 'The regional alternative to Uber, now owned by Uber. Ride-hailing, bike rentals, food delivery, and a digital wallet (Careem Pay). Most expats have both Careem and Uber installed.',
        category: 'Transport & Delivery',
      },
      {
        name: 'Uber',
        tagline: 'Ride-hailing worldwide',
        description: 'Works exactly as you would expect. Good coverage across Dubai, generally reliable. Uber Eats is also available for food delivery.',
        category: 'Transport',
      },
      {
        name: 'Deliveroo',
        tagline: 'Premium food delivery',
        description: 'Popular for restaurant delivery with a strong selection of higher-end restaurants. Deliveroo Plus subscription removes delivery fees if you order frequently.',
        category: 'Food Delivery',
      },
    ],
  },
  {
    name: 'Government & Official Services',
    description: 'The apps you need to interact with UAE government services. These are not optional.',
    apps: [
      {
        name: 'UAE Pass',
        tagline: 'Your digital identity - required',
        description: 'The UAE national digital identity app. You need this to access almost every government service online - from visa applications to utility connections. Set it up immediately after getting your Emirates ID.',
        category: 'Government',
      },
      {
        name: 'ICP (Federal Authority)',
        tagline: 'Visa and residency services',
        description: 'Manage your UAE visa and residency status, check visa validity, apply for entry permits, and track applications. Essential for anyone on a residence visa.',
        category: 'Government',
      },
      {
        name: 'Dubai REST',
        tagline: 'Dubai Land Department services',
        description: 'The official Dubai Land Department (DLD) app. Check property ownership records, verify title deeds, search transaction history, and access real estate services. Essential for property owners and buyers.',
        category: 'Government / Property',
      },
      {
        name: 'Dubai Police',
        tagline: 'Report incidents and pay fines',
        description: 'Report traffic accidents, pay traffic fines, request police clearance certificates, and access emergency services. You can report minor traffic incidents directly through the app without waiting for police to arrive.',
        category: 'Government',
      },
      {
        name: 'DEWA',
        tagline: 'Electricity and water services',
        description: 'Dubai Electricity and Water Authority app. Set up new connections, pay bills, track usage, and report faults. You will need a DEWA account for every property you own or rent in Dubai.',
        category: 'Utilities',
      },
      {
        name: 'RTA (nol)',
        tagline: 'Transport authority and nol card',
        description: 'Roads and Transport Authority app. Top up your nol card (used for metro, buses, trams, and water taxis), pay Salik toll charges, renew vehicle registration, and check public transport routes.',
        category: 'Transport',
      },
    ],
  },
  {
    name: 'Banking, Payments & Forex',
    description: 'Setting up your finances in the UAE is one of the first things you will need to do. Banking, international transfers, and forex are areas where the right advice saves you real money.',
    apps: [
      {
        name: 'Opening a Bank Account',
        tagline: 'Your first step after arriving',
        description: 'You will need a UAE bank account for salary, rent payments, and daily life. Major banks include Emirates NBD, FAB, ADCB, Mashreq, HSBC, and Standard Chartered. Requirements: passport, visa, Emirates ID, and salary certificate. Most banks now offer online applications.',
        category: 'Banking',
      },
      {
        name: 'Apple Pay / Samsung Pay',
        tagline: 'Contactless payments',
        description: 'Widely accepted across Dubai. Most UAE banks support Apple Pay and Samsung Pay. Tap-to-pay works at almost every shop, restaurant, and supermarket.',
        category: 'Payments',
      },
      {
        name: 'Forex & International Transfers',
        tagline: 'Get in touch for recommendations',
        description: 'Sending money home or moving funds internationally? The right forex and transfer provider can save you thousands in fees and exchange rate margins. I work with trusted partners who specialise in expat transfers. Get in touch and I will point you in the right direction.',
        category: 'Get in Touch',
      },
      {
        name: 'Mortgage & Finance Advice',
        tagline: 'Specialist guidance for buyers',
        description: 'If you are buying property in Dubai, getting the right mortgage advice early makes a real difference. I work with experienced mortgage advisors who can help with pre-approval, rate comparison, and the full application process. Reach out and I will connect you.',
        category: 'Get in Touch',
      },
    ],
  },
  {
    name: 'Health & Wellbeing',
    description: 'Dubai has world-class healthcare. Here are the key services and facilities you should know about.',
    apps: [
      {
        name: 'DHA (Dubai Health Authority)',
        tagline: 'Health records and services',
        description: 'Access your medical records, book appointments at government health centres, view lab results, and manage health insurance. Your vaccination records are stored here.',
        category: 'Government Health',
      },
      {
        name: "King's College Hospital London (Dubai Hills)",
        tagline: 'Premium hospital in Dubai Hills Estate',
        description: "A branch of the renowned London hospital, located in Dubai Hills Estate. Offers emergency, inpatient, and outpatient services across multiple specialities. One of the top reasons families choose to live in the Dubai Hills area.",
        category: 'Hospital',
      },
      {
        name: 'Mediclinic',
        tagline: 'Major hospital and clinic network',
        description: 'One of the largest private healthcare providers in the UAE. Mediclinic City Hospital (DIFC/Downtown area), Mediclinic Parkview Hospital (MBR City), and clinics across Dubai. Widely accepted by major insurance providers.',
        category: 'Hospital & Clinics',
      },
      {
        name: 'Aster Clinics & Hospitals',
        tagline: 'Accessible healthcare across Dubai',
        description: 'Large network of clinics and hospitals across Dubai. Aster Hospital (Al Qusais), Aster Clinic branches in most communities. Known for accessibility, reasonable pricing, and walk-in appointments.',
        category: 'Hospital & Clinics',
      },
      {
        name: 'American Hospital Dubai',
        tagline: 'Established premium hospital',
        description: 'One of the first private hospitals in Dubai, located in Oud Metha. Multi-speciality hospital with strong reputation for cardiology, orthopaedics, and maternity. JCI accredited.',
        category: 'Hospital',
      },
      {
        name: 'Emirates Hospital (Jumeirah)',
        tagline: 'Premium care on Jumeirah Beach Road',
        description: 'Private hospital on Jumeirah Beach Road offering specialist care, diagnostics, and outpatient services. Well-located for residents of Downtown, Business Bay, and Jumeirah communities.',
        category: 'Hospital',
      },
      {
        name: 'Okadoc',
        tagline: 'Book doctor appointments online',
        description: 'Find and book appointments with doctors, dentists, and specialists across Dubai. Filter by insurance provider, speciality, location, and availability. Reviews from other patients help you choose.',
        category: 'App',
      },
    ],
  },
  {
    name: 'Home Services & Maintenance',
    description: 'Apps and services for keeping your home running smoothly - cleaning, repairs, handyman work, and more.',
    apps: [
      {
        name: 'JustLife',
        tagline: 'Home cleaning and beauty services',
        description: 'Book professional cleaning, deep cleaning, AC servicing, pest control, and beauty treatments directly through the app. Rated professionals, transparent pricing, and easy rescheduling. One of the most-used home service apps in Dubai.',
        category: 'Home Services',
      },
      {
        name: 'Urban Company',
        tagline: 'Handyman, plumbing, and more',
        description: 'On-demand home services including plumbing, electrical work, painting, carpentry, appliance repair, and cleaning. All professionals are vetted and rated. Also offers salon-at-home and spa services.',
        category: 'Home Services',
      },
      {
        name: 'Speedy Spanners',
        tagline: 'Mobile mechanic - they come to you (highly recommended)',
        description: 'One of the best finds in Dubai. A mobile mechanic service that comes to your home, office, or apartment car park. Oil changes, battery replacement, brake pads, AC regas, full diagnostics, and general servicing - all done on-site while you carry on with your day. Transparent pricing, professional service, and it saves you the half-day you would otherwise lose sitting in a garage. I recommend Speedy Spanners to every client who asks about car maintenance in Dubai.',
        category: 'Car Maintenance',
      },
      {
        name: 'ServiceMarket',
        tagline: 'Compare home and moving services',
        description: 'Compare quotes from movers, cleaners, handymen, pest control, and home maintenance providers. Useful for getting competitive pricing on bigger jobs like deep cleaning before move-in or end-of-tenancy cleans.',
        category: 'Home Services',
      },
    ],
  },
  {
    name: 'Moving & Relocation',
    description: 'Whether you are moving within Dubai or arriving from overseas, these services handle the heavy lifting.',
    apps: [
      {
        name: 'Removal/Moving Companies',
        tagline: 'Local and international movers',
        description: 'For local moves within Dubai, companies like The Box, Movesouq, and Allied Moving offer packing and transport. For international relocations, Crown Relocations, Santa Fe, and AGS are well-established. Always get at least three quotes. Check Google reviews and ask your agent for a recommendation.',
        category: 'Moving',
      },
      {
        name: 'The Box (Self-Storage)',
        tagline: 'Storage solutions across Dubai',
        description: 'Self-storage units available in multiple Dubai locations. Useful if you are between homes, downsizing, or need overflow storage. Climate-controlled units available. They also offer pick-up and delivery of your boxes.',
        category: 'Storage',
      },
      {
        name: 'Fetchr / Shipa',
        tagline: 'Courier and delivery services',
        description: 'Same-day and next-day courier services across Dubai and the UAE. Useful for sending documents, parcels, or anything that needs delivering across the city.',
        category: 'Delivery',
      },
    ],
  },
  {
    name: 'Car Rental & Transport',
    description: 'Getting around Dubai. Whether you need a daily rental, long-term lease, or just a ride.',
    apps: [
      {
        name: 'ekar',
        tagline: 'Car-sharing by the minute',
        description: 'UAE-based car-sharing app. Pick up and drop off cars across Dubai without a subscription. Pay by the minute or hour. Great for occasional drivers who do not need a full-time car. Available across Dubai including Downtown, Marina, and JBR.',
        category: 'Car Sharing',
      },
      {
        name: 'Udrive',
        tagline: 'Flexible car rental',
        description: 'Similar to ekar - flexible car rental by the hour or day. No deposits, no paperwork. Cars are parked across the city and you unlock them through the app.',
        category: 'Car Sharing',
      },
      {
        name: 'Hertz / Europcar / Budget',
        tagline: 'Traditional car rental',
        description: 'The major international rental companies all operate in Dubai. Available at both airports and across the city. For longer rentals (monthly), local companies like Thrifty, Fast Rent A Car, and Diamondlease often offer better rates.',
        category: 'Car Rental',
      },
      {
        name: 'Salik',
        tagline: 'Road toll payments',
        description: 'Dubai has electronic road toll gates (Salik). If you drive, you need a Salik tag on your windshield. The app lets you top up your account, track charges, and manage your vehicle. AED 4 per gate crossing.',
        category: 'Tolls',
      },
      {
        name: 'Darb (Abu Dhabi Toll)',
        tagline: 'Abu Dhabi road tolls',
        description: 'If you drive to Abu Dhabi regularly, you will need the Darb toll system too. Separate from Salik. Register your vehicle and top up through the app.',
        category: 'Tolls',
      },
    ],
  },
  {
    name: 'Money-Saving Apps & Deals',
    description: 'Dubai can be expensive, but smart residents use these apps to save thousands every year.',
    apps: [
      {
        name: 'Entertainer',
        tagline: 'Buy-one-get-one-free everything',
        description: 'The most popular discount app in the UAE. Buy-one-get-one-free offers at hundreds of restaurants, attractions, spas, and activities. The annual subscription pays for itself within a few uses. Almost every Dubai resident has this.',
        category: 'Deals',
      },
      {
        name: 'Smiles (Etisalat/e&)',
        tagline: 'Rewards and cashback on everyday spending',
        description: 'The e& (formerly Etisalat) rewards app. Earn points on purchases and redeem them for discounts at restaurants, groceries, fuel, and entertainment. If you are on an e& mobile plan, you are already earning points.',
        category: 'Rewards',
      },
      {
        name: 'Fazaa',
        tagline: 'Government employee discount card',
        description: 'If you work for a government or semi-government entity in the UAE, you may qualify for a Fazaa card. Discounts at thousands of outlets including restaurants, hotels, healthcare, education, and retail.',
        category: 'Discount Card',
      },
      {
        name: 'Groupon / Cobone',
        tagline: 'Daily deals and vouchers',
        description: 'Discounted deals on restaurants, spa treatments, activities, and experiences across Dubai. Good for trying new places at a reduced price. Check reviews before buying.',
        category: 'Deals',
      },
      {
        name: 'Noon VIP / Amazon Prime',
        tagline: 'Free delivery and exclusive deals',
        description: 'Noon VIP and Amazon Prime UAE both offer free delivery, early access to sales, and exclusive discounts. If you order online regularly, the subscription fees pay for themselves quickly.',
        category: 'Subscription',
      },
      {
        name: 'Tabby / Tamara',
        tagline: 'Buy now, pay later (interest-free)',
        description: 'Split purchases into four interest-free payments. Widely accepted across Dubai retailers both online and in-store. Useful for larger purchases, but only if you stay on top of the payment schedule.',
        category: 'Payments',
      },
    ],
  },
  {
    name: 'Lifestyle & Getting Around',
    description: 'Making the most of life in Dubai.',
    apps: [
      {
        name: 'Zomato',
        tagline: 'Restaurant discovery and reviews',
        description: 'Find restaurants, read reviews, view menus, and book tables. More review-focused than Talabat or Deliveroo. Useful for discovering new places to eat.',
        category: 'Food & Dining',
      },
      {
        name: 'Google Maps',
        tagline: 'Navigation - with a Dubai twist',
        description: 'Works well in Dubai but be aware that some newer developments and buildings may not be fully mapped. Most people navigate by landmark rather than street name. "Next to the big Adnoc petrol station" is a valid direction in Dubai.',
        category: 'Navigation',
      },
    ],
  },
];
---
<PageLayout
  title="Dubai Essentials - Apps & Tools Every Resident Needs | AskDaveDowntown"
  description="Apps and tools you need when moving to Dubai. Government services, banking, food delivery, transport, and lifestyle explained for newcomers."
>
  <Section dark class="py-24">
    <div class="text-center max-w-3xl mx-auto" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 border border-accent/30 mb-8">
        <div class="w-2 h-2 rounded-full bg-accent"></div>
        <span class="text-xs tracking-[0.2em] uppercase text-accent font-medium">New to Dubai</span>
      </div>
      <h1 class="font-heading text-5xl sm:text-6xl font-bold text-paper leading-none">
        Dubai Essentials
      </h1>
      <p class="mt-6 text-paper/60 leading-relaxed text-lg">
        The apps and tools you actually need when you move to Dubai. The ones I use myself and recommend to every client.
      </p>
    </div>
  </Section>

  <div class="gold-line"></div>

  {categories.map((category, catIndex) => (
    <Section dark={catIndex % 2 !== 0}>
      <div class="max-w-5xl mx-auto">
        <div class="mb-8" data-animate>
          <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-3">{category.name}</p>
          <p class={`text-sm leading-relaxed ${catIndex % 2 !== 0 ? 'text-paper/60' : 'text-ink-muted'}`}>{category.description}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-stagger>
          {category.apps.map((app) => (
            <div class={`p-6 border ${catIndex % 2 !== 0 ? 'border-paper/10' : 'border-border'}`} data-animate>
              <div class="flex items-start justify-between mb-2">
                <div>
                  <h3 class={`font-heading text-lg font-bold ${catIndex % 2 !== 0 ? 'text-paper' : 'text-ink'}`}>{app.name}</h3>
                  <p class="text-accent text-xs font-medium mt-0.5">{app.tagline}</p>
                </div>
                <span class={`text-[10px] tracking-wide uppercase px-2 py-1 border ${catIndex % 2 !== 0 ? 'border-paper/10 text-paper/40' : 'border-border text-ink-muted'}`}>{app.category}</span>
              </div>
              <p class={`text-sm leading-relaxed mt-3 ${catIndex % 2 !== 0 ? 'text-paper/60' : 'text-ink-muted'}`}>{app.description}</p>
            </div>
          ))}
        </div>
      </div>
    </Section>
  ))}

  <!-- CTA -->
  <div class="gold-line"></div>
  <Section class="py-16">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <p class="text-xs tracking-[0.2em] uppercase text-accent font-semibold mb-4">Need Help Settling In?</p>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-ink">
        Moving to Dubai is the Easy Part
      </h2>
      <p class="mt-4 text-ink-muted leading-relaxed">
        Finding the right home in the right community is what makes the difference. Whether you are renting or buying, I can help you navigate the process from start to finish.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="https://wa.me/971503019926" variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
          WhatsApp Dave
        </Button>
        <Button href="mailto:dave.buckley@paragonproperties.ae" variant="primary" size="lg">Email Dave</Button>
        <Button href={`${base}areas`} variant="secondary">
          Explore Area Guides
        </Button>
      </div>
    </div>
  </Section>
</PageLayout>
