---
import { getCollection } from 'astro:content';
import readingTime from 'reading-time';
import BlogLayout from '../../layouts/BlogLayout.astro';
import ArticleSchema from '../../components/seo/ArticleSchema.astro';
import AuthorBio from '../../components/content/AuthorBio.astro';
import ShareButtons from '../../components/content/ShareButtons.astro';
import RelatedPosts from '../../components/content/RelatedPosts.astro';
import ReadingTime from '../../components/content/ReadingTime.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const rtResult = readingTime(post.body);
const readingMinutes = Math.ceil(rtResult.minutes);

const formattedPublishDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(post.data.publishDate);

const formattedUpdatedDate = post.data.updatedDate
  ? new Intl.DateTimeFormat('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(post.data.updatedDate)
  : null;

const categoryLabels: Record<string, string> = {
  'buying-guide': 'Buying Guide',
  'market-update': 'Market Update',
  'area-insight': 'Area Insight',
  'investment': 'Investment',
  'legal': 'Legal',
  'lifestyle': 'Lifestyle',
};

const canonicalUrl = new URL(`/blog/${post.slug}`, Astro.site).toString();
---
<BlogLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
>
  <ArticleSchema
    slot="head"
    title={post.data.title}
    description={post.data.description}
    publishDate={post.data.publishDate}
    updatedDate={post.data.updatedDate}
    heroImage={post.data.heroImage}
    authorName={post.data.author}
    url={canonicalUrl}
  />

  <article class="max-w-7xl mx-auto px-4 py-12">
    <!-- Post Header -->
    <header class="max-w-3xl mx-auto mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 text-xs font-medium uppercase tracking-wider bg-[var(--color-paper-muted)] text-[var(--color-ink-muted)] rounded">
          {categoryLabels[post.data.category] || post.data.category}
        </span>
        <ReadingTime minutes={readingMinutes} />
      </div>
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-ink)] leading-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-lg text-[var(--color-ink-muted)] mb-6">{post.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-[var(--color-ink-muted)]">
        <span>By {post.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={post.data.publishDate.toISOString()}>{formattedPublishDate}</time>
        {formattedUpdatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {formattedUpdatedDate}</span>
          </>
        )}
      </div>
    </header>

    <!-- Hero Image -->
    {post.data.heroImage && (
      <div class="max-w-4xl mx-auto mb-10 rounded-xl overflow-hidden">
        <img
          src={post.data.heroImage}
          alt={post.data.heroImageAlt || post.data.title}
          width={1200}
          height={630}
          class="w-full h-auto"
          loading="eager"
        />
      </div>
    )}

    <!-- Content + Sidebar -->
    <div class="grid lg:grid-cols-[1fr_300px] gap-12 max-w-5xl mx-auto">
      <!-- Main Content -->
      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-[var(--color-ink)] prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>

      <!-- Sidebar -->
      <aside class="flex flex-col gap-8 lg:sticky lg:top-8 lg:self-start">
        <AuthorBio />
        <ShareButtons title={post.data.title} url={canonicalUrl} />
        {post.data.relatedSlugs && post.data.relatedSlugs.length > 0 && (
          <RelatedPosts slugs={post.data.relatedSlugs} currentSlug={post.slug} />
        )}
      </aside>
    </div>
  </article>
</BlogLayout>
