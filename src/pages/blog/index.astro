---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/content/BlogCard.astro';
import CategoryFilter from '../../components/content/CategoryFilter.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featuredPost = posts.find((post) => post.data.featured);
const regularPosts = posts.filter((post) => !post.data.featured || post !== featuredPost);

const categories = ['buying-guide', 'market-update', 'area-insight', 'investment', 'legal', 'lifestyle'];

const categoryLabels: Record<string, string> = {
  'buying-guide': 'Buying Guide',
  'market-update': 'Market Update',
  'area-insight': 'Area Insight',
  'investment': 'Investment',
  'legal': 'Legal',
  'lifestyle': 'Lifestyle',
};
---
<PageLayout
  title="Dubai Property Blog | Expert Insights from Dave Buckley"
  description="Expert articles on buying property in Dubai, investment tips, area guides and market updates from RERA-registered agent Dave Buckley."
>
  <section class="pt-16 pb-8 px-4 max-w-7xl mx-auto">
    <div class="mb-10" data-animate>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-[var(--color-ink)] mb-4">
        Dubai Property Insights
      </h1>
      <p class="text-lg text-[var(--color-ink-muted)] max-w-2xl">
        Practical advice on buying, investing, and living in Dubai. Written by a broker who lives here - not a content team who has never visited.
      </p>
    </div>

    {featuredPost && (
      <div class="mb-12" data-animate>
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-4">Featured</p>
        <article class="group grid md:grid-cols-2 gap-8 bg-white border border-[var(--color-border)] rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300">
          {featuredPost.data.heroImage && (
            <a href={`/blog/${featuredPost.slug}`} class="block overflow-hidden aspect-[16/9] md:aspect-auto">
              <img
                src={featuredPost.data.heroImage}
                alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                width={800}
                height={500}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </a>
          )}
          <div class="flex flex-col justify-center p-8">
            <span class="inline-block px-3 py-1 text-xs font-medium uppercase tracking-wider bg-[var(--color-paper-muted)] text-[var(--color-ink-muted)] rounded mb-4 w-fit">
              {categoryLabels[featuredPost.data.category] || featuredPost.data.category}
            </span>
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-[var(--color-ink)] mb-3 leading-tight">
              <a href={`/blog/${featuredPost.slug}`} class="hover:text-[var(--color-accent)] transition-colors">
                {featuredPost.data.title}
              </a>
            </h2>
            <p class="text-[var(--color-ink-muted)] mb-6 leading-relaxed">{featuredPost.data.description}</p>
            <a
              href={`/blog/${featuredPost.slug}`}
              class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors"
            >
              Read article
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      </div>
    )}

    <div class="mb-8" data-animate>
      <CategoryFilter categories={categories} />
    </div>

    {regularPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-animate>
        {regularPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-[var(--color-ink-muted)]" data-animate>
        <p class="text-lg">No posts yet - check back soon.</p>
        <p class="text-sm mt-2">Dave is writing expert content on Dubai property. It will be here shortly.</p>
      </div>
    )}

    {posts.length === 0 && (
      <div class="text-center py-20 text-[var(--color-ink-muted)]" data-animate>
        <p class="text-lg">No posts yet - check back soon.</p>
        <p class="text-sm mt-2">Dave is writing expert content on Dubai property. It will be here shortly.</p>
      </div>
    )}
  </section>
</PageLayout>
